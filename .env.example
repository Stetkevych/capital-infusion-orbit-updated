# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mca_lending

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Plaid Integration
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# DocuSign Integration
DOCUSIGN_INTEGRATION_KEY=your_docusign_integration_key
DOCUSIGN_USER_ID=your_docusign_user_id
DOCUSIGN_ACCOUNT_ID=your_docusign_account_id
DOCUSIGN_WEBHOOK_SECRET=your_docusign_webhook_secret

# Zoho CRM Integration
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_ACCOUNT_DOMAIN=com

# Underwriting/AU Gold Integration
UNDERWRITING_CLIENT_ID=your_underwriting_client_id
UNDERWRITING_API_SECRET=your_underwriting_api_secret

# AWS Configuration
AWS_REGION=us-east-1
AWS_S3_BUCKET=mca-lending-documents
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Frontend
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5000/api
