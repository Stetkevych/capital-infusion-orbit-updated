{
  "firebase": {
    "apiKey": "${FIREBASE_API_KEY}",
    "authDomain": "${FIREBASE_AUTH_DOMAIN}",
    "databaseURL": "${FIREBASE_DATABASE_URL}",
    "projectId": "${FIREBASE_PROJECT_ID}",
    "storageBucket": "${FIREBASE_STORAGE_BUCKET}",
    "messagingSenderId": "${FIREBASE_MESSAGING_SENDER_ID}"
  },
  "database": {
    "url": "${DATABASE_URL}",
    "pool": {
      "max": 20,
      "idleTimeoutMillis": 30000,
      "connectionTimeoutMillis": 2000
    }
  },
  "server": {
    "port": "${PORT:-5000}",
    "nodeEnv": "${NODE_ENV:-development}",
    "frontendUrl": "${FRONTEND_URL}",
    "apiBaseUrl": "${API_BASE_URL}"
  },
  "auth": {
    "jwtSecret": "${JWT_SECRET}",
    "jwtExpiry": "24h",
    "passwordHashRounds": 10
  },
  "aws": {
    "region": "${AWS_REGION:-us-east-1}",
    "s3Bucket": "${AWS_S3_BUCKET}",
    "accessKeyId": "${AWS_ACCESS_KEY_ID}",
    "secretAccessKey": "${AWS_SECRET_ACCESS_KEY}"
  },
  "integrations": {
    "plaid": {
      "clientId": "${PLAID_CLIENT_ID}",
      "secret": "${PLAID_SECRET}",
      "env": "${PLAID_ENV:-sandbox}"
    },
    "docusign": {
      "integrationKey": "${DOCUSIGN_INTEGRATION_KEY}",
      "userId": "${DOCUSIGN_USER_ID}",
      "accountId": "${DOCUSIGN_ACCOUNT_ID}",
      "webhookSecret": "${DOCUSIGN_WEBHOOK_SECRET}"
    },
    "zoho": {
      "clientId": "${ZOHO_CLIENT_ID}",
      "clientSecret": "${ZOHO_CLIENT_SECRET}",
      "refreshToken": "${ZOHO_REFRESH_TOKEN}",
      "accountDomain": "${ZOHO_ACCOUNT_DOMAIN}"
    },
    "underwriting": {
      "clientId": "${UNDERWRITING_CLIENT_ID}",
      "apiSecret": "${UNDERWRITING_API_SECRET}"
    }
  },
  "logging": {
    "level": "${LOG_LEVEL:-info}",
    "format": "json"
  },
  "security": {
    "corsOrigins": ["${FRONTEND_URL}"],
    "rateLimit": {
      "windowMs": 900000,
      "max": 100,
      "message": "Too many requests from this IP"
    },
    "helmet": {
      "contentSecurityPolicy": false,
      "crossOriginEmbedderPolicy": false
    }
  }
}
